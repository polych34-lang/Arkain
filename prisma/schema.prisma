// ARKAIN database schema (PostgreSQL via Prisma).
//
// FOUNDATION ONLY. This is the seed of the unified domain model; the full
// product/order/settlement normalization is owned by ENG-Domain-Model. What is
// here defines the durable spine: sellers, their (encrypted) marketplace
// connections, and a sync-run audit trail for correctness/debugging.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Marketplace {
  naver_smartstore
  coupang
  eleven_st
  esm_2_0
}

/// ARK-10 (per ADR-0002, docs/adr/0002-multi-tenancy-b2b-b2c.md): `Seller`
/// doubles as ARKAIN's tenant boundary — one row per seller business onboarded
/// onto ARKAIN, the unit Postgres RLS isolates on. There is no separate
/// `Tenant` model; introducing one would duplicate this table with no
/// behavior difference today (upgrade path: insert `Tenant` above `Seller`
/// later if one customer ever owns multiple stores — every downstream column
/// is already named `tenantId`, not `sellerId`, to keep that door open).
model Seller {
  id                      String                  @id @default(uuid())
  displayName             String
  createdAt               DateTime                @default(now())
  connections             MarketplaceConnection[]
  orders                  Order[]
  products                Product[]
  settlements             Settlement[]
  accounts                Account[]
  accountPriceListEntries AccountPriceListEntry[]
  purchaseOrders          PurchaseOrder[]
  customers               Customer[]
  priceSegments           PriceSegment[]
  pricingRules            PricingRule[]
  modelSegDiscounts       ModelSegDiscount[]
  colorTaxonomies         ColorTaxonomy[]
  colorSurcharges         ColorSurcharge[]
  quotes                  Quote[]
}

/// A seller's link to one marketplace. The credential is stored ENCRYPTED
/// (AES-256-GCM envelope) — see src/secrets/credentialStore.ts. Plaintext
/// tokens never touch this table.
model MarketplaceConnection {
  id          String      @id @default(uuid())
  seller      Seller      @relation(fields: [sellerId], references: [id])
  sellerId    String
  marketplace Marketplace
  /// base64(iv).base64(authTag).base64(ciphertext)
  ciphertext  String
  keyVersion  Int         @default(1)
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  syncRuns    SyncRun[]

  @@unique([sellerId, marketplace])
}

/// Audit trail for every order-sync attempt. Critical for trust: when a number
/// looks wrong we can trace exactly which run produced it.
model SyncRun {
  id           String                @id @default(uuid())
  connection   MarketplaceConnection @relation(fields: [connectionId], references: [id])
  connectionId String
  startedAt    DateTime              @default(now())
  finishedAt   DateTime?
  status       String                @default("running") // running | success | failed
  ordersPulled Int                   @default(0)
  cursor       String?
  error        String?
}

// --- Unified domain model (ENG-Domain-Model / ARK-4) ------------------------
//
// Every marketplace adapter produces the `Normalized*` types in
// src/integrations/marketplace.ts; src/domain/*.ts maps those into the rows
// below. A second marketplace (쿠팡) means adding one status-mapping table and
// one mapper file — these tables and their unique keys never change.

/// Marketplace-agnostic order status. `MIXED` covers a Naver `orderId` whose
/// line items (`productOrderId`s) have diverged statuses (e.g. partial
/// cancellation) — see src/integrations/naver/naver.mapper.ts. `UNKNOWN` is the
/// safe default for any raw status we haven't mapped yet; `rawStatus` on the
/// row always preserves the marketplace's original string for audit.
enum OrderStatus {
  PENDING
  PAID
  DISPATCHED
  DELIVERED
  CONFIRMED
  CANCELLED
  RETURNED
  EXCHANGED
  MIXED
  UNKNOWN
}

/// Marketplace-agnostic listing status.
enum ProductStatus {
  ON_SALE
  OUT_OF_STOCK
  SUSPENDED
  UNKNOWN
}

/// Unified order. One row per marketplace order (`orderId` for Naver), not per
/// line item — see OrderItem. Idempotent upsert key: (marketplace,
/// marketplaceOrderId), matching the local JSON store's key from the ARK-3
/// spike so re-running a sync never double-counts.
model Order {
  id                 String       @id @default(uuid())
  /// ARK-10 (ADR-0002 §2b): tenant boundary (-> Seller.id). Required — every
  /// write path (OrderSyncEngine) sets it, there's no pre-migration data to
  /// backfill (no migration has ever run against a live DB — see
  /// docs/multi-tenancy.md). Enforced again at the DB layer by Postgres RLS.
  tenant             Seller       @relation(fields: [tenantId], references: [id])
  tenantId           String
  /// ARK-35: which customer placed this order, once phone-matched against
  /// `customers`. Nullable — no matching service exists yet (that lands with
  /// the CS/견적 issue that consumes `customer_activity`); every existing and
  /// newly-synced Order starts unlinked.
  customer           Customer?    @relation(fields: [customerId], references: [id])
  customerId         String?
  marketplace        Marketplace
  marketplaceOrderId String
  status             OrderStatus
  /// Marketplace's raw status string, kept verbatim (mapping is best-effort
  /// and unverified against live data until ARK-3's credential blocker clears).
  rawStatus          String
  orderedAt          DateTime
  buyerName          String?
  /// Integer KRW (minor unit = won; there are no smaller units). No floats.
  totalAmountKrw     Int
  items              OrderItem[]
  settlements        Settlement[]
  /// ARK-42: quotes converted into this order (Quote.convertedOrderId). No
  /// conversion logic yet (design doc §5) — structural hook only.
  convertedFromQuotes Quote[]
  /// Untouched normalized-order payload (which itself retains the marketplace
  /// raw response) — see ARCHITECTURE.md §6 "every number must be traceable".
  raw                Json
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  /// Scoped per tenant so two sellers can never collide on the same
  /// marketplace order id (the ARK-10 bug this migration fixes — the prior
  /// key had no tenant scope at all).
  @@unique([tenantId, marketplace, marketplaceOrderId])
}

/// One line item within an Order (Naver `productOrderId`). Deliberately has
/// no `tenantId` of its own (ADR-0002 §2b): it's only ever reached via its
/// parent Order (nested create/include, cascade delete), so RLS on `Order`
/// already scopes it in every query path this app has today. A denormalized
/// copy here would be copy-paste scoping that can drift out of sync — see
/// docs/multi-tenancy.md for the residual gap this accepts (a future
/// direct/raw query against OrderItem alone would not be RLS-protected).
model OrderItem {
  id                   String @id @default(uuid())
  order                Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId              String
  marketplaceProductId String
  productName          String
  quantity             Int
  unitPriceKrw         Int
}

/// Unified product/listing. Idempotent upsert key: (tenantId, marketplace,
/// marketplaceProductId) — the channel-level listing id, matching the ARK-3
/// spike's key, now scoped per tenant (ARK-10).
model Product {
  id                   String        @id @default(uuid())
  tenant               Seller        @relation(fields: [tenantId], references: [id])
  tenantId             String
  marketplace          Marketplace
  marketplaceProductId String
  /// The marketplace's catalog/origin id when distinct from the listing id
  /// (Naver: one origin product can have multiple channel products).
  originProductId      String?
  name                 String
  salePriceKrw         Int
  stockQuantity        Int
  status               ProductStatus
  rawStatus            String
  raw                  Json
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([tenantId, marketplace, marketplaceProductId])
}

/// Settlement/payout line. Foundation slice only (ARK-4): no marketplace
/// adapter produces settlement data yet — that mapping lands with ARK-7. The
/// shape here is deliberately minimal and will grow once real payout payloads
/// are seen; correctness conventions (integer KRW, raw preserved) already
/// apply so ARK-7 has no schema debt to pay down. `tenantId` (ARK-10) added
/// now so ARK-7 has no migration debt either.
model Settlement {
  id                 String      @id @default(uuid())
  tenant             Seller      @relation(fields: [tenantId], references: [id])
  tenantId           String
  marketplace        Marketplace
  order              Order?      @relation(fields: [orderId], references: [id])
  orderId            String?
  marketplaceOrderId String?
  settledAt          DateTime?
  payoutAmountKrw    Int
  feeAmountKrw       Int
  raw                Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([tenantId, marketplace, marketplaceOrderId])
}

// --- Customer identity (ARK-35, per feature-audit §2.3/§5) ------------------
//
// The reference OMS has no `customers` table at all — customer identity is
// two free-text phone columns compared as strings across `naver_inquiries`
// and `orders`, which makes repurchase/LTV/a 360-degree customer view
// structurally impossible. Building this table now, before any CS/quote
// feature exists to write to it, is the late-mover advantage: everything
// downstream (Quote, Inquiry, when those land) links to `Customer` from day
// one instead of retrofitting a merge key later.

/// One customer, identified by normalized phone number within a tenant. Reuses
/// the ARK-10 tenant boundary (`Seller`) and RLS pattern verbatim — see
/// prisma/migrations/20260703000000_customers_activity_view and
/// docs/multi-tenancy.md.
model Customer {
  id              String    @id @default(uuid())
  tenant          Seller    @relation(fields: [tenantId], references: [id])
  tenantId        String
  /// Digits only (hyphens/whitespace stripped) — the merge key across
  /// channels. Normalization happens at the write path once one exists (no
  /// writer yet — see the Order.customerId comment); the column itself is the
  /// durable invariant.
  primaryPhone    String
  primaryEmail    String?
  name            String
  /// e.g. {"naver": ["Q123", "T_xxx"]} — per-channel identifiers this
  /// customer is known by, so a future CS view can jump from a channel
  /// inquiry id back to this row without a second lookup table.
  channelIds      Json?
  firstInquiryAt  DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]
  quotes          Quote[]

  @@unique([tenantId, primaryPhone])
}

// --- Pricing / Quote module (ARK-36 design, ARK-42 implementation) --------
//
// DB-izes what the reference OMS keeps as a single tenant-wide localStorage
// blob (`pricing_rules`/`color_surcharge`) plus its 3-tier price master
// (`cost_pricing` -> `price_segments` -> `model_seg_discounts`) — see the
// ARK-36 schema design doc for the full rationale. `QuoteItem` snapshots
// every price-calculation input alongside the result so a later
// PricingRule/ModelSegDiscount/ColorSurcharge change can never alter a past
// quote's amount.

enum ModelSegPriceType {
  WHOLESALE // 도매
  RETAIL // 소비자
  EVENT // 이벤트
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
}

/// 업종 세그먼트 마스터 (ARK-36/42). Segment definitions are entirely
/// tenant-defined — no list is seeded (each business's 업종 mix differs).
model PriceSegment {
  id        String   @id @default(uuid())
  tenant    Seller   @relation(fields: [tenantId], references: [id])
  tenantId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingRules      PricingRule[]
  modelSegDiscounts ModelSegDiscount[]
  colorSurcharges   ColorSurcharge[]
  quoteItems        QuoteItem[]

  @@unique([tenantId, code])
}

/// 가격계산 규칙 (ARK-36/42) — replaces the reference's single tenant-wide
/// localStorage `pricing_rules` blob with a per-(tenant, segment) row so
/// wholesale/discount factors can differ by 업종.
model PricingRule {
  id              String       @id @default(uuid())
  tenant          Seller       @relation(fields: [tenantId], references: [id])
  tenantId        String
  segment         PriceSegment @relation(fields: [segmentId], references: [id])
  segmentId       String
  /// 도매가 = 정가 x wholesaleFactor (레퍼런스 기본값 0.70)
  wholesaleFactor Decimal      @db.Decimal(6, 4)
  /// 수량할인 10/20/30단위 팩터
  d10Factor       Decimal      @db.Decimal(6, 4)
  d20Factor       Decimal      @db.Decimal(6, 4)
  d30Factor       Decimal      @db.Decimal(6, 4)
  /// 최종 단가 반올림 단위(원)
  roundUnit       Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([tenantId, segmentId])
}

/// 모델×업종×가격유형별 할인율 (ARK-36/42) — tenant-scoped version of the
/// reference's UNIQUE(model_name, segment_id, price_type).
model ModelSegDiscount {
  id           String            @id @default(uuid())
  tenant       Seller            @relation(fields: [tenantId], references: [id])
  tenantId     String
  segment      PriceSegment      @relation(fields: [segmentId], references: [id])
  segmentId    String
  /// Freeform, matching the reference — Product has no normalized model
  /// entity yet.
  modelName    String
  priceType    ModelSegPriceType
  discountRate Decimal           @db.Decimal(6, 4)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([tenantId, segmentId, modelName, priceType])
}

/// 색상 원본값 -> 정규화 라벨 (ARK-36/42). Segment-independent — a color name
/// doesn't change by 업종, only its surcharge amount does (see
/// ColorSurcharge).
model ColorTaxonomy {
  id           String   @id @default(uuid())
  tenant       Seller   @relation(fields: [tenantId], references: [id])
  tenantId     String
  rawValue     String
  groupLabel   String
  material     String?
  displayLabel String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  surcharges ColorSurcharge[]

  @@unique([tenantId, rawValue])
}

/// 색상 가산값 (ARK-36/42), tenant+segment scoped — same color can cost
/// differently by 업종 (원가 차이).
model ColorSurcharge {
  id              String        @id @default(uuid())
  tenant          Seller        @relation(fields: [tenantId], references: [id])
  tenantId        String
  segment         PriceSegment  @relation(fields: [segmentId], references: [id])
  segmentId       String
  colorTaxonomy   ColorTaxonomy @relation(fields: [colorTaxonomyId], references: [id])
  colorTaxonomyId String
  surchargeKrw    Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([tenantId, segmentId, colorTaxonomyId])
}

/// 견적 (ARK-36/42). `customerId` nullable for the same reason as
/// `Order.customerId` (ARK-35) — customer matching is a later batch job.
/// `convertedOrderId` is a structural hook only; actual Quote->Order
/// conversion logic is out of scope (design doc §5).
model Quote {
  id               String      @id @default(uuid())
  tenant           Seller      @relation(fields: [tenantId], references: [id])
  tenantId         String
  customer         Customer?   @relation(fields: [customerId], references: [id])
  customerId       String?
  status           QuoteStatus @default(DRAFT)
  totalAmountKrw   Int?
  convertedOrder   Order?      @relation(fields: [convertedOrderId], references: [id])
  convertedOrderId String?
  items            QuoteItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

/// 견적 항목 (ARK-36/42). No own tenantId/RLS — same reasoning as OrderItem
/// (ADR-0002 §2b): always reached through its parent Quote. The unit-price
/// snapshot fields are this model's entire purpose: every input that fed the
/// price calculation is stored alongside the result, so later changes to
/// PricingRule/ModelSegDiscount/ColorSurcharge never alter a past quote's
/// amount — callers must read `unitPriceKrw`/`lineTotalKrw` as-is and never
/// recompute them.
model QuoteItem {
  id          String @id @default(uuid())
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  productName String
  modelName   String
  color       String
  quantity    Int

  // --- calculation-input snapshot: segment/model stay resolvable even if
  // the referenced segment is later deleted (segmentId goes null, code
  // string remains) ---
  segment              PriceSegment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  segmentId            String?
  segmentCodeSnapshot  String?
  priceType            ModelSegPriceType
  basePriceKrw         Int
  discountRateSnapshot Decimal           @db.Decimal(6, 4)
  colorSurchargeKrw    Int               @default(0)
  roundUnitSnapshot    Int

  // --- result snapshot: read-only, never recomputed ---
  unitPriceKrw Int
  lineTotalKrw Int

  createdAt DateTime @default(now())

  @@index([quoteId])
}

// --- B2B module: 거래처(Account) + 대량발주(PurchaseOrder) (ARK-16) ---------
//
// Deliberately separate from Order/OrderItem/Product — see
// docs/adr/0003-b2b-accounts-purchase-orders.md for why. These orders have no
// marketplace origin at all (entered directly, approved internally), so they
// don't fit Order's (marketplace, marketplaceOrderId) upsert key or
// OrderStatus's marketplace-fulfillment states. tenantId is enforced at the
// application layer today (explicit `where: { tenantId }`, no RLS yet) — same
// interim posture ADR-0002 §2d describes for Order pre-ARK-10.

enum AccountPriceTier {
  WHOLESALE // 도매
  CONSUMER // 소비자
  EVENT // 이벤트
}

/// 거래처: a direct wholesale/business buyer, distinct from a marketplace
/// consumer. One row per tenant per business relationship.
model Account {
  id                     String                  @id @default(uuid())
  tenant                 Seller                  @relation(fields: [tenantId], references: [id])
  tenantId               String
  name                   String
  businessRegistrationNo String?
  priceTier              AccountPriceTier        @default(WHOLESALE)
  contactName            String?
  contactPhone           String?
  memo                   String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  priceListEntries       AccountPriceListEntry[]
  purchaseOrders         PurchaseOrder[]

  @@index([tenantId])
}

/// One account's negotiated unit price for one SKU. `sku` is a freeform
/// internal product code — deliberately not a foreign key to `Product`
/// (a marketplace listing), since a wholesale-only SKU need not be listed on
/// any marketplace.
model AccountPriceListEntry {
  id           String   @id @default(uuid())
  tenant       Seller   @relation(fields: [tenantId], references: [id])
  tenantId     String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId    String
  sku          String
  productName  String
  unitPriceKrw Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([accountId, sku])
}

/// DRAFT -> SUBMITTED -> {APPROVED|REJECTED}; APPROVED -> FULFILLED;
/// {DRAFT|SUBMITTED} -> CANCELLED. Enforced by
/// src/domain/b2b/purchaseOrderStateMachine.ts, not by the DB.
enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  FULFILLED
  CANCELLED
}

/// A 거래처 대량발주: entered directly, no MarketplaceAdapter involved.
model PurchaseOrder {
  id              String              @id @default(uuid())
  tenant          Seller              @relation(fields: [tenantId], references: [id])
  tenantId        String
  account         Account             @relation(fields: [accountId], references: [id])
  accountId       String
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmountKrw  Int
  memo            String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  items           PurchaseOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  sku             String
  productName     String
  quantity        Int
  unitPriceKrw    Int
  lineTotalKrw    Int
}
