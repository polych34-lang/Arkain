// ARKAIN database schema (PostgreSQL via Prisma).
//
// FOUNDATION ONLY. This is the seed of the unified domain model; the full
// product/order/settlement normalization is owned by ENG-Domain-Model. What is
// here defines the durable spine: sellers, their (encrypted) marketplace
// connections, and a sync-run audit trail for correctness/debugging.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Marketplace {
  naver_smartstore
  coupang
  eleven_st
  esm_2_0
}

/// ARK-10 (per ADR-0002, docs/adr/0002-multi-tenancy-b2b-b2c.md): `Seller`
/// doubles as ARKAIN's tenant boundary — one row per seller business onboarded
/// onto ARKAIN, the unit Postgres RLS isolates on. There is no separate
/// `Tenant` model; introducing one would duplicate this table with no
/// behavior difference today (upgrade path: insert `Tenant` above `Seller`
/// later if one customer ever owns multiple stores — every downstream column
/// is already named `tenantId`, not `sellerId`, to keep that door open).
model Seller {
  id                      String                  @id @default(uuid())
  displayName             String
  createdAt               DateTime                @default(now())
  connections             MarketplaceConnection[]
  orders                  Order[]
  products                Product[]
  settlements             Settlement[]
  accounts                Account[]
  accountPriceListEntries AccountPriceListEntry[]
  purchaseOrders          PurchaseOrder[]
  customers               Customer[]
  inquiries               Inquiry[]
}

/// A seller's link to one marketplace. The credential is stored ENCRYPTED
/// (AES-256-GCM envelope) — see src/secrets/credentialStore.ts. Plaintext
/// tokens never touch this table.
model MarketplaceConnection {
  id          String      @id @default(uuid())
  seller      Seller      @relation(fields: [sellerId], references: [id])
  sellerId    String
  marketplace Marketplace
  /// base64(iv).base64(authTag).base64(ciphertext)
  ciphertext  String
  keyVersion  Int         @default(1)
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  syncRuns    SyncRun[]

  @@unique([sellerId, marketplace])
}

/// Audit trail for every order-sync attempt. Critical for trust: when a number
/// looks wrong we can trace exactly which run produced it.
model SyncRun {
  id           String                @id @default(uuid())
  connection   MarketplaceConnection @relation(fields: [connectionId], references: [id])
  connectionId String
  startedAt    DateTime              @default(now())
  finishedAt   DateTime?
  status       String                @default("running") // running | success | failed
  ordersPulled Int                   @default(0)
  cursor       String?
  error        String?
}

// --- Unified domain model (ENG-Domain-Model / ARK-4) ------------------------
//
// Every marketplace adapter produces the `Normalized*` types in
// src/integrations/marketplace.ts; src/domain/*.ts maps those into the rows
// below. A second marketplace (쿠팡) means adding one status-mapping table and
// one mapper file — these tables and their unique keys never change.

/// Marketplace-agnostic order status. `MIXED` covers a Naver `orderId` whose
/// line items (`productOrderId`s) have diverged statuses (e.g. partial
/// cancellation) — see src/integrations/naver/naver.mapper.ts. `UNKNOWN` is the
/// safe default for any raw status we haven't mapped yet; `rawStatus` on the
/// row always preserves the marketplace's original string for audit.
enum OrderStatus {
  PENDING
  PAID
  DISPATCHED
  DELIVERED
  CONFIRMED
  CANCELLED
  RETURNED
  EXCHANGED
  MIXED
  UNKNOWN
}

/// Marketplace-agnostic listing status.
enum ProductStatus {
  ON_SALE
  OUT_OF_STOCK
  SUSPENDED
  UNKNOWN
}

/// Unified order. One row per marketplace order (`orderId` for Naver), not per
/// line item — see OrderItem. Idempotent upsert key: (marketplace,
/// marketplaceOrderId), matching the local JSON store's key from the ARK-3
/// spike so re-running a sync never double-counts.
model Order {
  id                 String             @id @default(uuid())
  /// ARK-10 (ADR-0002 §2b): tenant boundary (-> Seller.id). Required — every
  /// write path (OrderSyncEngine) sets it, there's no pre-migration data to
  /// backfill (no migration has ever run against a live DB — see
  /// docs/multi-tenancy.md). Enforced again at the DB layer by Postgres RLS.
  tenant             Seller             @relation(fields: [tenantId], references: [id])
  tenantId           String
  /// ARK-35: which customer placed this order, once phone-matched against
  /// `customers`. Nullable — no matching service exists yet (that lands with
  /// the CS/견적 issue that consumes `customer_activity`); every existing and
  /// newly-synced Order starts unlinked.
  customer           Customer?          @relation(fields: [customerId], references: [id])
  customerId         String?
  marketplace        Marketplace
  marketplaceOrderId String
  status             OrderStatus
  /// Marketplace's raw status string, kept verbatim (mapping is best-effort
  /// and unverified against live data until ARK-3's credential blocker clears).
  rawStatus          String
  orderedAt          DateTime
  buyerName          String?
  /// Integer KRW (minor unit = won; there are no smaller units). No floats.
  totalAmountKrw     Int
  items              OrderItem[]
  settlements        Settlement[]
  /// ARK-37: manual/auto links to CS inquiries concerning this order.
  inquiryLinks       InquiryOrderLink[]
  /// Untouched normalized-order payload (which itself retains the marketplace
  /// raw response) — see ARCHITECTURE.md §6 "every number must be traceable".
  raw                Json
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  /// Scoped per tenant so two sellers can never collide on the same
  /// marketplace order id (the ARK-10 bug this migration fixes — the prior
  /// key had no tenant scope at all).
  @@unique([tenantId, marketplace, marketplaceOrderId])
}

/// One line item within an Order (Naver `productOrderId`). Deliberately has
/// no `tenantId` of its own (ADR-0002 §2b): it's only ever reached via its
/// parent Order (nested create/include, cascade delete), so RLS on `Order`
/// already scopes it in every query path this app has today. A denormalized
/// copy here would be copy-paste scoping that can drift out of sync — see
/// docs/multi-tenancy.md for the residual gap this accepts (a future
/// direct/raw query against OrderItem alone would not be RLS-protected).
model OrderItem {
  id                   String @id @default(uuid())
  order                Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId              String
  marketplaceProductId String
  productName          String
  quantity             Int
  unitPriceKrw         Int
}

/// Unified product/listing. Idempotent upsert key: (tenantId, marketplace,
/// marketplaceProductId) — the channel-level listing id, matching the ARK-3
/// spike's key, now scoped per tenant (ARK-10).
model Product {
  id                   String        @id @default(uuid())
  tenant               Seller        @relation(fields: [tenantId], references: [id])
  tenantId             String
  marketplace          Marketplace
  marketplaceProductId String
  /// The marketplace's catalog/origin id when distinct from the listing id
  /// (Naver: one origin product can have multiple channel products).
  originProductId      String?
  name                 String
  salePriceKrw         Int
  stockQuantity        Int
  status               ProductStatus
  rawStatus            String
  raw                  Json
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  inquiries            Inquiry[]

  @@unique([tenantId, marketplace, marketplaceProductId])
}

/// Settlement/payout line. Foundation slice only (ARK-4): no marketplace
/// adapter produces settlement data yet — that mapping lands with ARK-7. The
/// shape here is deliberately minimal and will grow once real payout payloads
/// are seen; correctness conventions (integer KRW, raw preserved) already
/// apply so ARK-7 has no schema debt to pay down. `tenantId` (ARK-10) added
/// now so ARK-7 has no migration debt either.
model Settlement {
  id                 String      @id @default(uuid())
  tenant             Seller      @relation(fields: [tenantId], references: [id])
  tenantId           String
  marketplace        Marketplace
  order              Order?      @relation(fields: [orderId], references: [id])
  orderId            String?
  marketplaceOrderId String?
  settledAt          DateTime?
  payoutAmountKrw    Int
  feeAmountKrw       Int
  raw                Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([tenantId, marketplace, marketplaceOrderId])
}

// --- Customer identity (ARK-35, per feature-audit §2.3/§5) ------------------
//
// The reference OMS has no `customers` table at all — customer identity is
// two free-text phone columns compared as strings across `naver_inquiries`
// and `orders`, which makes repurchase/LTV/a 360-degree customer view
// structurally impossible. Building this table now, before any CS/quote
// feature exists to write to it, is the late-mover advantage: everything
// downstream (Quote, Inquiry, when those land) links to `Customer` from day
// one instead of retrofitting a merge key later.

/// One customer, identified by normalized phone number within a tenant. Reuses
/// the ARK-10 tenant boundary (`Seller`) and RLS pattern verbatim — see
/// prisma/migrations/20260703000000_customers_activity_view and
/// docs/multi-tenancy.md.
model Customer {
  id              String    @id @default(uuid())
  tenant          Seller    @relation(fields: [tenantId], references: [id])
  tenantId        String
  /// Digits only (hyphens/whitespace stripped) — the merge key across
  /// channels. Normalization happens at the write path once one exists (no
  /// writer yet — see the Order.customerId comment); the column itself is the
  /// durable invariant.
  primaryPhone    String
  primaryEmail    String?
  name            String
  /// e.g. {"naver": ["Q123", "T_xxx"]} — per-channel identifiers this
  /// customer is known by, so a future CS view can jump from a channel
  /// inquiry id back to this row without a second lookup table.
  channelIds      Json?
  firstInquiryAt  DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]
  inquiries       Inquiry[]

  @@unique([tenantId, primaryPhone])
}

// --- CS channel unification (ARK-37, per feature-audit §2.3/§4) ------------
//
// The reference OMS unifies its 4 CS channels (상품문의/고객문의/톡톡/카카오) into one
// `naver_inquiries` table, with TalkTalk/Kakao's conversational messages held in
// an append-only `channel_messages` table that a DB trigger rolls up into the
// parent row. That append-only design is the verified fix for the reference's
// v455 image-loss bug (feature-audit §4): the old flow read the current
// content, appended a message client-side, and wrote it back — two concurrent
// messages landing in that window silently dropped one image/message
// (read-modify-write race). Making the message log INSERT-only and letting a
// trigger do the append inside the same transaction as the INSERT removes the
// race by construction — there's no read-then-write step for two writers to
// interleave. Adopted verbatim, per the issue's explicit instruction.

/// The reference's 4 channels, keyed by inquiry-number prefix there (Q/C/T/K);
/// an explicit enum here instead of parsing a prefix.
enum InquiryChannel {
  PRODUCT_QNA // 상품문의 (Q) — tied to a specific listing, see `productId`
  CUSTOMER_QNA // 고객문의 (C) — general CS, usually 1:1 with one order
  TALK // 네이버 톡톡 (T) — conversational, uses `ChannelMessage`
  KAKAO // 카카오 (K) — conversational, uses `ChannelMessage`
}

enum InquiryStatus {
  OPEN
  ANSWERED
  CLOSED
}

/// One CS inquiry across all 4 channels (feature-audit §2.3's `naver_inquiries`
/// unification, adopted verbatim). `content` holds the inquiry body directly
/// for PRODUCT_QNA/CUSTOMER_QNA (single message, no conversation); for
/// TALK/KAKAO it is maintained by the `fn_channel_message_rollup` trigger,
/// which atomically appends each new `ChannelMessage` — never read-modify-write
/// from application code (see the section comment above).
model Inquiry {
  id                String             @id @default(uuid())
  tenant            Seller             @relation(fields: [tenantId], references: [id])
  tenantId          String
  channel           InquiryChannel
  /// The channel's own inquiry id (Naver's `inquiry_no`, e.g. "Q123"/"T_xxx") —
  /// paired with `channel` (not `marketplace`, see below) as the idempotent
  /// upsert key, matching the `(tenantId, marketplace, marketplaceOrderId)`
  /// pattern `Order` uses (ARK-10).
  externalInquiryNo String
  /// Nullable: TALK/KAKAO run through Naver/Kakao respectively, but KAKAO is a
  /// messaging channel, not one of the `Marketplace` enum's storefronts — no
  /// value fits, so this is a descriptive attribute here, not part of the
  /// natural key (that's `channel` + `externalInquiryNo` above). A NOT NULL
  /// `marketplace` would also make the natural key's uniqueness unreliable:
  /// Postgres treats NULLs as distinct in unique constraints, so two KAKAO
  /// rows with the same tenant/externalInquiryNo but both marketplace=NULL
  /// would NOT collide — a latent gap this design avoids by construction.
  marketplace       Marketplace?
  /// ARK-35: which customer asked, once phone-matched against `customers`.
  /// Nullable for the same reason as `Order.customerId` — no matching service
  /// exists yet, so every inquiry starts unlinked.
  customer          Customer?          @relation(fields: [customerId], references: [id])
  customerId        String?
  /// Direct snapshot of the channel's reported contact info — populated at
  /// ingestion regardless of match status, same reasoning as `Order.buyerName`
  /// alongside its nullable `customerId`: an inquiry must be usable before any
  /// matching has run.
  customerName      String?
  customerPhone     String?
  /// Which listing this concerns — only meaningful for PRODUCT_QNA, per the
  /// issue's "품목 구분 컬럼" ask. Nullable: CUSTOMER_QNA/TALK/KAKAO have no
  /// single listing, and even for PRODUCT_QNA the listing may not have a
  /// matching `Product` row (sync timing/deleted listing).
  product           Product?           @relation(fields: [productId], references: [id])
  productId         String?
  subject           String?
  content           String
  status            InquiryStatus      @default(OPEN)
  answeredAt        DateTime?
  /// Untouched original channel payload, same convention as Order.raw.
  raw               Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  messages          ChannelMessage[]
  orderLinks        InquiryOrderLink[]

  /// Channel (not marketplace) + the channel's own id — see the `marketplace`
  /// comment above for why.
  @@unique([tenantId, channel, externalInquiryNo])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

/// TALK/KAKAO conversation messages — append-only (INSERT only, no
/// UPDATE/DELETE grant; see prisma/migrations for the enforcing `REVOKE`).
/// This table is the source of truth the reference's v455 fix relies on: an
/// image/message is durable the moment its row is inserted, before the
/// `fn_channel_message_rollup` trigger even runs, so a concurrent second
/// insert can never overwrite it. Deliberately has no `tenantId` of its own —
/// same reasoning as `OrderItem` (ADR-0002 §2b): only ever reached via its
/// parent `Inquiry` (already RLS'd); see docs/multi-tenancy.md for the
/// residual gap this accepts (a future direct query against `ChannelMessage`
/// alone would not be RLS-protected).
model ChannelMessage {
  id          String           @id @default(uuid())
  inquiry     Inquiry          @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  inquiryId   String
  direction   MessageDirection
  content     String
  /// Image/file rehosting (per the issue's explicit ask): each entry is
  /// `{originalUrl, rehostedUrl, rehostStatus, rehostedAt}`. The reference
  /// rehosts to its own storage with a 6s timeout and falls back to
  /// `originalUrl` on failure/timeout, because Naver's CDN URLs expire —
  /// `rehostedUrl` stays null and `rehostStatus` records the fallback so the
  /// UI/a retry job can tell "no attachment" apart from "rehost failed, using
  /// original (may 404 later)". No rehosting worker exists yet in this repo
  /// (would need live Naver Talk/Kakao credentials, still gated on ARK-22) —
  /// this column is the storage shape a future rehosting job writes to.
  attachments Json?
  sentAt      DateTime
  createdAt   DateTime         @default(now())

  @@index([inquiryId, sentAt])
}

enum MessageDirection {
  CUSTOMER
  SELLER
}

/// 문의↔주문 연결 (feature-audit §2.3): CUSTOMER_QNA auto-matches 1:1 via its
/// order context in the reference; PRODUCT_QNA/TALK need a manual link since
/// one inquiry can span multiple orders (or vice versa) — hence the composite
/// PK / join-table shape rather than a single FK on either side.
model InquiryOrderLink {
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  inquiryId String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  /// "auto" (CUSTOMER_QNA 1:1 match) | "manual" (PRODUCT_QNA/TALK link UI) —
  /// free-form per the issue's SQL sketch (feature-audit §2.3); no fixed link
  /// UI exists yet to warrant an enum.
  linkType  String?
  linkedAt  DateTime @default(now())

  @@id([inquiryId, orderId])
}

// --- B2B module: 거래처(Account) + 대량발주(PurchaseOrder) (ARK-16) ---------
//
// Deliberately separate from Order/OrderItem/Product — see
// docs/adr/0003-b2b-accounts-purchase-orders.md for why. These orders have no
// marketplace origin at all (entered directly, approved internally), so they
// don't fit Order's (marketplace, marketplaceOrderId) upsert key or
// OrderStatus's marketplace-fulfillment states. tenantId is enforced at the
// application layer today (explicit `where: { tenantId }`, no RLS yet) — same
// interim posture ADR-0002 §2d describes for Order pre-ARK-10.

enum AccountPriceTier {
  WHOLESALE // 도매
  CONSUMER // 소비자
  EVENT // 이벤트
}

/// 거래처: a direct wholesale/business buyer, distinct from a marketplace
/// consumer. One row per tenant per business relationship.
model Account {
  id                     String                  @id @default(uuid())
  tenant                 Seller                  @relation(fields: [tenantId], references: [id])
  tenantId               String
  name                   String
  businessRegistrationNo String?
  priceTier              AccountPriceTier        @default(WHOLESALE)
  contactName            String?
  contactPhone           String?
  memo                   String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  priceListEntries       AccountPriceListEntry[]
  purchaseOrders         PurchaseOrder[]

  @@index([tenantId])
}

/// One account's negotiated unit price for one SKU. `sku` is a freeform
/// internal product code — deliberately not a foreign key to `Product`
/// (a marketplace listing), since a wholesale-only SKU need not be listed on
/// any marketplace.
model AccountPriceListEntry {
  id           String   @id @default(uuid())
  tenant       Seller   @relation(fields: [tenantId], references: [id])
  tenantId     String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId    String
  sku          String
  productName  String
  unitPriceKrw Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([accountId, sku])
}

/// DRAFT -> SUBMITTED -> {APPROVED|REJECTED}; APPROVED -> FULFILLED;
/// {DRAFT|SUBMITTED} -> CANCELLED. Enforced by
/// src/domain/b2b/purchaseOrderStateMachine.ts, not by the DB.
enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  FULFILLED
  CANCELLED
}

/// A 거래처 대량발주: entered directly, no MarketplaceAdapter involved.
model PurchaseOrder {
  id              String              @id @default(uuid())
  tenant          Seller              @relation(fields: [tenantId], references: [id])
  tenantId        String
  account         Account             @relation(fields: [accountId], references: [id])
  accountId       String
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmountKrw  Int
  memo            String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  items           PurchaseOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  sku             String
  productName     String
  quantity        Int
  unitPriceKrw    Int
  lineTotalKrw    Int
}
