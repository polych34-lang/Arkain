# ARKAIN environment template.
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# In staging/production these are injected by the platform secret manager,
# not read from a committed file. See ARCHITECTURE.md "Secrets & credentials".

# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (PostgreSQL) ---
# Local dev via docker-compose: postgres/postgres on localhost:5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arkain?schema=public

# --- Marketplace credential encryption ---
# 32-byte key (base64) used to envelope-encrypt seller marketplace credentials
# at rest. Generate locally: `openssl rand -base64 32`. Rotate via key versioning.
# This is a DEV placeholder only — real keys live in the platform secret manager.
CREDENTIAL_ENC_KEY=ZGV2LW9ubHktcGxhY2Vob2xkZXIta2V5LTMyYnl0ZXMhIQ==

# --- Naver Commerce API (NO real seller creds in this file) ---
# App-level credentials for the ARKAIN application registered on Naver Commerce.
# Per-seller tokens are stored encrypted in the credential store, not here.
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=
NAVER_COMMERCE_BASE_URL=https://api.commerce.naver.com
