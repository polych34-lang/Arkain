{
  "name": "arkain",
  "version": "0.1.0",
  "private": true,
  "description": "ARKAIN — multi-market seller management (사방넷-class). Order-sync MVP.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "naver:pull": "tsx src/scripts/naver-pull.ts",
    "esm:pull": "tsx src/scripts/esm-pull.ts",
    "coupang:pull": "tsx src/scripts/coupang-pull.ts",
    "seed:demo": "tsx src/scripts/seed-demo-orders.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
